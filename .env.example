# LumiLab environment configuration
DATA_MODE=mock
PORT=3001
TARGET_SITE_URL=https://www.adkivo.my.id
CRAWL_LIMIT=8
REQUEST_TIMEOUT_MS=15000
RESPECT_ROBOTS=true

# Related project (read-only — LumiLab does not modify this repo)
# https://github.com/DyesDefalt/adswift-guide.git
# Preview: https://adkivomy-p4f0dvyao-adie-azzams-projects.vercel.app

# BYOK AI Assistant (backend only — never expose to frontend)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Live GA4 / GSC (set DATA_MODE=live when service account is configured)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json
GSC_SITE_URL=https://adkivo.my.id/
MATON_API_KEY=

# Puppeteer PDF — optional path to system Chrome if bundled browser unavailable
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Safety — no automatic website edits in MVP
ACTIONS_ENABLED=false
